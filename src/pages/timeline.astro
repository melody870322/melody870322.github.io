---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n/utils';
import { timelineData } from '../data/timeline';

const locale = 'en';
const i = t(locale);
---

<BaseLayout
  title={i.timeline_page.title}
  description="Academic experience and service of Shih-Ting Wang"
  lang="en"
>
  <section class="section">
    <div class="container">
      <ol class="timeline">
        {timelineData.map((group) => (
          <li class="year-group">
            <div class="year-col">
              <span class="year">{group.year}</span>
            </div>
            <ul class="year-items">
              {group.items.map((item) => (
                <li class="item">
                  <span class={`tag tag-${item.category}`}>
                    {i.timeline_page.categories[item.category]}
                  </span>
                  <p class="item-text" set:html={item.en} />
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .timeline-header {
    margin-bottom: var(--space-16);
  }

  .timeline-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: var(--space-3);
  }

  .timeline-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .year-group {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-12);
    position: relative;
  }

  .year-group:last-child {
    padding-bottom: 0;
  }

  .year-col {
    position: sticky;
    top: calc(var(--header-height) + var(--space-6));
    align-self: start;
    text-align: right;
  }

  .year {
    display: inline-block;
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-heading);
    font-family: var(--font-mono);
    letter-spacing: -0.02em;
  }

  .year-items {
    list-style: none;
    padding: 0 0 0 var(--space-6);
    margin: 0;
    border-left: 2px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .item {
    position: relative;
    padding-top: 0.35rem;
  }

  .item::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-6) - 6px);
    top: 0.8rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-bg);
    border: 2px solid var(--color-accent);
    transition: all var(--transition);
  }

  .item:hover::before {
    background-color: var(--color-accent);
    transform: scale(1.15);
  }

  .item-text {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text);
  }

  .item-text :global(em) {
    color: var(--color-text-secondary);
  }

  /* ===== Category tags ===== */
  .tag {
    display: inline-block;
    padding: 0.15rem var(--space-3);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: 9999px;
    letter-spacing: 0.02em;
    border: 1px solid transparent;
  }

  .tag-honor {
    background-color: #fef3c7;
    color: #b45309;
    border-color: #fde68a;
  }

  .tag-advising {
    background-color: #dcfce7;
    color: #15803d;
    border-color: #bbf7d0;
  }

  .tag-teaching {
    background-color: #dbeafe;
    color: #1d4ed8;
    border-color: #bfdbfe;
  }

  .tag-service {
    background-color: #f3e8ff;
    color: #7c3aed;
    border-color: #e9d5ff;
  }

  .tag-assistant {
    background-color: #f1f5f9;
    color: #475569;
    border-color: #e2e8f0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .timeline-title {
      font-size: var(--text-3xl);
    }

    .year-group {
      grid-template-columns: 1fr;
      gap: var(--space-4);
      padding-bottom: var(--space-10);
    }

    .year-col {
      position: static;
      text-align: left;
    }

    .year {
      font-size: var(--text-xl);
    }

    .year-items {
      padding-left: var(--space-5);
    }

    .item::before {
      left: calc(-1 * var(--space-5) - 6px);
    }
  }
</style>
