const fullServerPy = String.raw`from typing import Any

import httpx
from mcp.server.fastmcp import FastMCP

mcp = FastMCP("Stable Weather API Assistant")

OPEN_METEO_API_URL = "https://api.open-meteo.com/v1/forecast"

CITY_LOCATIONS = {
    "Taipei": {
        "latitude": 25.0330,
        "longitude": 121.5654,
    },
    "Taichung": {
        "latitude": 24.1477,
        "longitude": 120.6736,
    },
    "Kaohsiung": {
        "latitude": 22.6273,
        "longitude": 120.3014,
    },
    "Tamsui": {
        "latitude": 25.1676,
        "longitude": 121.4458,
    },
}

CITY_ALIASES = {
    "taipei": "Taipei",
    "TAIPEI": "Taipei",
    "Taipei City": "Taipei",
    "taichung": "Taichung",
    "Taichung City": "Taichung",
    "kaohsiung": "Kaohsiung",
    "Kaohsiung City": "Kaohsiung",
    "tamsui": "Tamsui",
}


def success_response(
    city: str,
    update_time: str,
    temperature: float,
    wind_speed: float,
) -> str:
    return (
        "Status: success\n"
        f"City: {city}\n"
        f"Updated: {update_time}\n"
        f"Temperature: ~{temperature} °C\n"
        f"Wind speed: ~{wind_speed} km/h\n"
        "Note: live data from an external weather API. "
        "Conditions may still vary by exact location and time."
    )


def error_response(reason: str, suggestion: str) -> str:
    return (
        "Status: failed\n"
        f"Reason: {reason}\n"
        f"Suggestion: {suggestion}"
    )


def normalize_city_name(city: str) -> str:
    city = city.strip()
    return CITY_ALIASES.get(city, city)


@mcp.tool()
def hello() -> str:
    """Confirm the stable weather API MCP server is up."""
    return "Stable Weather API MCP server is running."


@mcp.tool()
def list_supported_cities() -> str:
    """List the cities currently supported."""
    cities = ", ".join(CITY_LOCATIONS.keys())
    return f"Supported cities: {cities}"


@mcp.tool()
def get_current_weather(city: str) -> str:
    """Look up current weather for a city, with a fixed response format."""
    city = normalize_city_name(city)

    if not city:
        return error_response(
            reason="No city name provided.",
            suggestion="Please pass a city name, e.g. Taipei, Taichung, Kaohsiung, Tamsui.",
        )

    if city not in CITY_LOCATIONS:
        supported_cities = ", ".join(CITY_LOCATIONS.keys())
        return error_response(
            reason=f"\"{city}\" is not supported.",
            suggestion=f"Try one of these instead: {supported_cities}.",
        )

    location = CITY_LOCATIONS[city]

    params = {
        "latitude": location["latitude"],
        "longitude": location["longitude"],
        "current": "temperature_2m,wind_speed_10m",
        "timezone": "Asia/Taipei",
    }

    try:
        with httpx.Client(timeout=10.0) as client:
            response = client.get(OPEN_METEO_API_URL, params=params)
            response.raise_for_status()
            data: dict[str, Any] = response.json()
    except httpx.TimeoutException:
        return error_response(
            reason="The weather API took too long to respond.",
            suggestion="Please try again later, or check your network.",
        )
    except httpx.HTTPStatusError as error:
        return error_response(
            reason=f"The weather API returned an error. Status code: {error.response.status_code}.",
            suggestion="Please try again later. If it keeps failing, the API may be temporarily down.",
        )
    except httpx.RequestError:
        return error_response(
            reason="Couldn't reach the weather API.",
            suggestion="Please check your network, or verify the API URL is correct.",
        )

    current = data.get("current", {})

    temperature = current.get("temperature_2m")
    wind_speed = current.get("wind_speed_10m")
    update_time = current.get("time")

    if temperature is None or wind_speed is None or update_time is None:
        return error_response(
            reason="The API responded, but a required field is missing.",
            suggestion="Please try again later. If this persists, the API doc may have changed.",
        )

    return success_response(
        city=city,
        update_time=update_time,
        temperature=temperature,
        wind_speed=wind_speed,
    )


if __name__ == "__main__":
    mcp.run()
`;
