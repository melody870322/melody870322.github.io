import BaseLayout from '../../../../layouts/BaseLayout.astro';

const fullServerPy = String.raw`from pathlib import Path
from mcp.server.fastmcp import FastMCP

mcp = FastMCP("Course Notes Assistant")

BASE_DIR = Path(__file__).parent
NOTES_DIR = BASE_DIR / "class_notes"
DRAFTS_DIR = BASE_DIR / "drafts"


def safe_note_path(filename: str) -> Path:
    """Make sure the AI can only read .md files inside class_notes."""
    name = Path(filename).name

    if name != filename:
        raise ValueError("Please pass a filename only, not a folder path.")

    path = NOTES_DIR / name

    if path.suffix != ".md":
        raise ValueError("Only .md notes are allowed for now.")

    return path


def safe_draft_filename(title: str) -> str:
    """Turn the title into a reasonably safe filename."""
    safe_title = "".join(
        ch for ch in title
        if ch.isalnum() or ch in (" ", "-", "_")
    ).strip()

    safe_title = safe_title.replace(" ", "_")

    if not safe_title:
        safe_title = "reflection_draft"

    return f"{safe_title}.md"


@mcp.tool()
def hello() -> str:
    """Confirm the class-notes MCP server is up."""
    return "Class-notes MCP server is running."


@mcp.tool()
def list_notes() -> str:
    """List the class notes inside the class_notes folder."""
    if not NOTES_DIR.exists():
        return "class_notes folder not found. Please create it first."

    notes = sorted(path.name for path in NOTES_DIR.glob("*.md"))

    if not notes:
        return "No .md notes are inside class_notes yet."

    return "Available class notes:\n" + "\n".join(notes)


@mcp.tool()
def read_note(filename: str) -> str:
    """Read one class note from the class_notes folder."""
    try:
        path = safe_note_path(filename)
    except ValueError as error:
        return str(error)

    if not path.exists():
        return f"{filename} not found. Use list_notes to confirm the filename."

    return path.read_text(encoding="utf-8")


@mcp.tool()
def create_reflection_draft(title: str, content: str) -> str:
    """Create a new reflection draft inside drafts/ without overwriting existing files."""
    DRAFTS_DIR.mkdir(exist_ok=True)

    filename = safe_draft_filename(title)
    path = DRAFTS_DIR / filename

    if path.exists():
        return f"Draft already exists: {filename}. I did not overwrite it. Please use a different title."

    draft_text = f"# {title}\n\n{content}\n"
    path.write_text(draft_text, encoding="utf-8")

    return f"Draft created: {filename}"


@mcp.resource("course://reflection-rules")
def reflection_rules() -> str:
    """Provide the fixed rules for writing a class reflection draft."""
    return """
Class reflection drafts must follow these rules:

1. Do not finish the student's final assignment for them.
2. The content should read like the student's own notes, not a formal paper.
3. The draft must include three sections:
   - What I understood
   - Where I'm still stuck
   - How I might apply this
4. If the source material is thin, flag it to the user — do not fill in gaps.
5. Before creating a draft, tell the user which file will be written.
""".strip()


@mcp.prompt()
def draft_reflection(topic: str, filename: str) -> str:
    """Fixed flow for producing a class reflection draft."""
    return f"""
Please help me produce a reflection draft based on a class note.

Topic: {topic}
Note: {filename}

Follow this flow:

1. Use read_note to read the chosen note first.
2. Pull out the points relevant to the topic.
3. Consult the rules at course://reflection-rules.
4. Show me the draft for confirmation before writing anything.
5. Only after I agree, use create_reflection_draft to create the file.
""".strip()


if __name__ == "__main__":
    mcp.run()
`;

const aiAgentBasicsMd = `# AI Agent Basics

## What this note is about

This note is for people who are just starting out with AI agents.

We're not rushing into code or hooking up a bunch of tools yet.
First, let's get a few basic roles straight:

- AI is the part doing the understanding and reasoning
- CLI is where we work with the AI
- MCP is the shared protocol for letting AI use tools
- API is how we actually talk to external services

Once these roles are clear, learning Gemini CLI, MCP servers, Notion, Google Drive, or any other tool gets a lot less tangled.

---

## AI is more than a chatbot

Most people first meet AI through chat.

For example:

- Summarize an article
- Rewrite a paragraph
- Brainstorm a report topic
- Pull out the key points

These are all useful, but an AI agent is trying to go one step further.

An AI agent doesn't just answer you — it can use tools to get a task done.

For example:

- Read a note
- Search a folder
- Create a draft
- Compile a class reflection
- Call an external service's API

In other words, an AI agent is more like an "AI work partner that knows how to use tools."

---

## The LLM understands your intent

Think of the large language model as the AI's brain.

It understands what you said, figures out what you're trying to accomplish, and decides what to do next.

For example, if you say:

> Please put together a class reflection draft based on my Week 1 notes.

The AI needs to understand a few things:

1. You want a class reflection
2. You're pointing at the Week 1 notes
3. You want a draft, not a final version
4. It probably needs to read the notes first, then organize them

But the LLM itself can't always read your files directly.

If you want it to actually pull data from a local folder, a Notion page, or a Google Drive document, it needs tools.

---

## Gemini CLI is where you and the AI work together

CLI stands for Command Line Interface — think of it as a "text-based workspace."

Gemini CLI is the tool that lets you work with Gemini in a terminal.

You type tasks in, and the AI helps you analyze, organize, read files, or call tools.

It's less like a chat app and more like a workbench.

In that workbench, you can give the AI access to project data and connect more tools through MCP.

So the role of Gemini CLI is:

> The shared workspace where you and the AI collaborate.

---

## MCP is the shared protocol for AI tooling

MCP stands for Model Context Protocol.

You can think of it as:

> A shared protocol for AI to talk to tools.

Without a shared protocol, every tool would have to be wired up its own way — chaos.

The idea behind MCP is:

Tool providers package their capabilities as an MCP server.
Tools like Gemini CLI act as MCP clients.
Through this protocol, the AI knows what tools are available, what each tool needs as input, and what it returns.

Put simply:

- MCP server: the tool provider
- MCP client: the connector
- AI: the one deciding when to use a tool

---

## API is how we actually do things to external services

Think of an API as "an external service's operation entry point."

Services like Notion, Google Drive, GitHub, and Slack typically expose APIs.

Through an API, code can:

- Look up data
- Create pages
- Update content
- Read files
- Add records

The relationship between MCP and API is:

The API is what the service itself exposes.
An MCP server can wrap an API into something AI can use comfortably.
Gemini CLI then lets the AI call those wrapped tools through the MCP server.

So API is the underlying capability; MCP is the wrapping and protocol layer.

---

## More tools isn't always better

A common early thought is:

If AI can use tools, isn't more tools always better?

Not really.

More tools means more reach, but also more risk.

For example:

- It might read data it shouldn't
- It might modify content it shouldn't touch
- It might pick the wrong tool for the task
- It might act in the wrong place

So when designing an AI agent, don't just turn everything on. Ask first:

> Which tools does this task actually need?

Smaller is better. Clearer is better.

---

## Read first, write later

A practical principle when designing AI workflows:

> Read first, write later.

Meaning: don't let the AI modify, delete, or publish things from the start.

A safer flow looks like:

1. Let the AI read the data first
2. Let it organize what it understood
3. Let a human confirm
4. Then create a new draft
5. Only then consider updating the real content

The benefit: the human stays in the loop.

The AI helps, but the final judgment and responsibility still sit with you.

---

## AI agents aren't about full automation

"AI agent" sounds like "fully automated assistant."

But in learning and teaching contexts, full automation isn't necessarily the goal.

What matters more:

- Was the task broken down small enough?
- Do the tools have clear boundaries?
- Is there room for human confirmation?
- Can it stop when something goes wrong?
- Can the result be reviewed?

A good AI agent isn't one that does everything by itself.

A good AI agent knows when to act, when to ask, and when to stop.

---

## Takeaways

The main concepts to internalize:

AI isn't just chat — it can use tools to complete tasks.
Gemini CLI is where we work with the AI.
MCP is the shared protocol that lets AI use tools.
API is what an external service actually exposes.
More tools isn't better — think through the task and the boundaries first.
For your first AI workflow, read data and create new drafts; don't modify originals.

When you build your own MCP server next, these concepts turn into actual tools.

For example:

- List class notes
- Read a specific note
- Create a reflection draft
- Provide fixed reflection rules
- Let Gemini CLI call all of these
`;

const mcpPrimitivesMd = `# Roles of Tools, Resources, and Prompts

## What this note is about

When building an MCP server, a question comes up fast:

Should this thing be a tool, a resource, or a prompt?

All three are part of MCP, but they play different roles.

A one-line summary:

- Tool is a capability that does something
- Resource is reference content
- Prompt is a reusable workflow

If these three roles get mixed up, the MCP server gets messy fast.

---

## Tool: actually does something

A tool is the most "tool-like" thing.

It runs an action.

For example:

- List the notes in a folder
- Read a specific note
- Create a reflection draft
- Call an API for data
- Add a row of data
- Generate a file

If the thing changes state, reads external data, or performs a clear action, it's probably best as a tool.

In the class-notes helper:

\`\`\`python
@mcp.tool()
def list_notes() -> str:
    """List the class notes inside the class_notes folder."""
    ...
\`\`\`

\`list_notes\` is a tool because it goes to the folder and looks at what's there.

---

## Keep tools small — don't be greedy

A common mistake when designing tools:

Stuffing too much into one tool.

For example, designing a tool called:

\`\`\`text
manage_notes
\`\`\`

It sounds convenient, but it could mean any of:

- List notes
- Read a note
- Modify a note
- Delete a note
- Create a draft
- Organize content

That's too big.

When the AI sees a tool like that, it has trouble figuring out what's safe to do.

A better approach is to split it up:

- \`list_notes\`
- \`read_note\`
- \`create_reflection_draft\`

Each tool does one clear thing.

Easier to understand, easier to gate.

---

## Resource: fixed reference content

A resource is more like "data" or "reference content."

It's not for performing actions.

It's the background material the AI can read.

For example:

- Class reflection format
- Course rules
- Writing examples
- Project description
- Database field reference
- FAQ list

In the class-notes helper, a resource looks like:

\`\`\`text
course://reflection-rules
\`\`\`

It holds the fixed rules for writing a reflection draft.

For example:

1. Must include "what I understood"
2. Must include "where I'm still stuck"
3. Must include "how I might apply this"
4. Don't finish the student's final assignment
5. Flag thin source material to the user

This kind of content is best as a resource.

It's not an action — it's fixed reference material.

---

## Don't turn fixed rules into tools

If you only need the AI to see a set of rules, you don't need a tool.

For example:

\`\`\`text
get_reflection_rules
\`\`\`

The name reads like a tool, but if all it does is return fixed rules, it should be a resource.

Why:

A tool reads as "I'm going to do something."
A resource reads as "here's reference material to consult."

Putting fixed rules in a resource makes the MCP server clearer.

The AI can also tell:

This isn't an action to perform — it's content to consult while doing the task.

---

## Prompt: a reusable workflow

A prompt is a reusable task template.

It's not the tool itself, and it's not the data itself.

It's more like a job description.

The class-notes helper might have a prompt like:

\`\`\`text
draft_reflection
\`\`\`

It tells the AI:

1. Read the chosen note first
2. Pull out the points relevant to the topic
3. Consult the reflection rules
4. Show the user the draft for confirmation first
5. Only create the file after the user agrees

That's exactly what a prompt is good for.

It captures a common workflow so the user doesn't have to describe it from scratch every time.

---

## Prompt is not the same as a tool

Prompts and tools get conflated easily.

A way to separate them:

If it's saying "how to do something," it's more like a prompt.
If it's actually "performing an action," it's more like a tool.

For example:

\`\`\`text
Produce a class reflection draft based on the chosen note
\`\`\`

This is more like a prompt — it describes a workflow.

But:

\`\`\`text
Create a new draft file
\`\`\`

This is more like a tool — it actually writes a file.

So in the class-notes helper:

- \`draft_reflection\` is a prompt
- \`create_reflection_draft\` is a tool

They work together, but they're not the same thing.

---

## The three work together

Tools, resources, and prompts aren't competing — they form one clean workflow.

For example, a user says:

> Based on \`week1.md\`, with "my understanding of MCP" as the topic, please produce a reflection draft.

The AI can:

1. Use the prompt \`draft_reflection\` to understand the flow
2. Use the tool \`read_note\` to read \`week1.md\`
3. Consult the resource \`course://reflection-rules\`
4. Produce the draft content
5. Wait for the user's confirmation
6. Use the tool \`create_reflection_draft\` to create the file

Each piece has its own role.

Prompt handles the flow.
Resource handles the data.
Tool handles the action.

---

## A simple test

If you're not sure where a thing belongs, ask three questions.

First:

> Does it actually do something?

If yes — read a file, write a file, hit an API — it's probably a tool.

Second:

> Does it just provide reference material to the AI?

If yes — class rules, format guides, project descriptions — it's probably a resource.

Third:

> Is it describing a fixed workflow?

If yes — "first read, then summarize, then ask the user" — it's probably a prompt.

This isn't a perfect rule, but for beginners it's plenty.

---

## How the class-notes helper splits the roles

If we're building a "class-notes helper," it splits like this:

### Tools

\`\`\`text
hello
list_notes
read_note
create_reflection_draft
\`\`\`

These are action-performing tools.

\`hello\` confirms the MCP server is running.
\`list_notes\` lists the notes.
\`read_note\` reads a note.
\`create_reflection_draft\` creates a draft.

### Resource

\`\`\`text
course://reflection-rules
\`\`\`

This is the fixed reflection rules.

It's not an action — it's content the AI consults while drafting.

### Prompt

\`\`\`text
draft_reflection
\`\`\`

This is the reflection-drafting workflow.

It reminds the AI to read the note, organize key points, consult the rules, get human confirmation, and only then create the draft.

---

## Why this split is safer

A few benefits.

First: clearer boundaries.
You know which things actually do work, which just provide data, and which describe flows.

Second: easier permission control.
For instance, you can expose only:

\`\`\`text
list_notes
read_note
create_reflection_draft
\`\`\`

without offering a delete tool.

Third: easier debugging.
If the AI ignores a rule, the resource or prompt may be unclear.
If a file isn't created, the tool likely has a problem.
If the order is off, the prompt needs tuning.

Fourth: easier for students to follow.
Each piece has a clear role; it doesn't all blur together.

---

## Common mistakes

### Mistake 1: Making everything a tool

Some people end up making everything a tool.

Class rules become a tool, fixed instructions become a tool, the workflow becomes a tool.

The tool list gets messy.

The AI also has a harder time telling which tools actually act vs. just return data.

### Mistake 2: Tools that try to do too much

For example, a single \`manage_course\` that "does everything."

It looks convenient, but it's hard to control.

Better: split it into several smaller tools.

### Mistake 3: Asking the prompt to do something no tool supports

For example, a prompt that says:

\`\`\`text
Read everything from Google Drive
\`\`\`

But you never provided a Google Drive tool.

Now the AI either guesses or fails.

So prompts can't be wishful.

A prompt has to align with the tools you've actually exposed.

---

### Mistake 4: Overstuffed resources

A resource is reference material, not a junk drawer.

If you cram unrelated content in, the AI has a harder time finding what matters.

A good resource is short, clear, and on-topic.

---

## Takeaways

Tools, resources, and prompts have different roles.

Tool is a capability that does something.
Resource is fixed reference content.
Prompt is a reusable workflow.

When designing an MCP server, don't try to build a lot of features upfront.

Ask:

- Which actions does this task need?
- Which fixed reference material should the AI have?
- Which workflows can be packaged as prompts?
- Which capabilities should not be exposed?
- Which actions need human confirmation first?

When these questions are answered, the MCP server is much less likely to turn into a messy tool box.

A good MCP server isn't the one with the most tools.

A good MCP server is one where every tool, every piece of reference material, and every workflow has a clear purpose.
`;
