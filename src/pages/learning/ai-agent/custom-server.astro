---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Building Your Own MCP Server — AI Agent Puzzle"
  description="Build your own MCP Server from scratch and hook an AI agent up to a tool you've made yourself."
  lang="en"
>
  <section class="section">
    <div class="container ai-agent-custom-server">
      <a class="back-link" href="/">&larr; Back to Home</a>

      <header class="detail-header">
        <h1 class="detail-title">Building Your Own MCP Server</h1>
        <p class="detail-subtitle">
          Page under construction...
        </p>
      </header>

    </div>
  </section>
</BaseLayout>

<style>
  .ai-agent-custom-server {
    max-width: 52rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-8);
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .detail-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .detail-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .detail-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
</style>
