---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const locale = 'zh';
const i = t(locale);
---

<BaseLayout title={i.contact.title} description="聯絡王詩婷" lang="zh">
  <section class="section">
    <div class="container">
      <h1 class="page-title">{i.contact.title}</h1>
      <p class="page-subtitle">{i.contact.subtitle}</p>

      <div class="contact-grid">
        <!-- Email Card -->
        <div class="contact-card">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="M22 7l-10 7L2 7" />
            </svg>
          </div>
          <h2 class="card-title">{i.contact.email_section}</h2>
          <ul class="contact-list">
            <li>
              <span class="contact-label">{i.contact.personal}</span>
              <a class="contact-value" href="mailto:melody870322@gmail.com">melody870322@gmail.com</a>
            </li>
            <li>
              <span class="contact-label">TKU</span>
              <a class="contact-value" href="mailto:168082@o365.tku.edu.tw">168082@o365.tku.edu.tw</a>
            </li>
            <li>
              <span class="contact-label">NCHU</span>
              <a class="contact-value" href="mailto:d112061011@mail.nchu.edu.tw">d112061011@mail.nchu.edu.tw</a>
            </li>
          </ul>
        </div>

        <!-- Affiliation Card -->
        <div class="contact-card">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
              <path d="M6 12v5c3 3 9 3 12 0v-5" />
            </svg>
          </div>
          <h2 class="card-title">{i.contact.affiliation_section}</h2>
          <ul class="contact-list">
            <li>
              <span class="contact-label">{i.contact.nchu}</span>
              <span class="contact-value">{i.contact.nchu_dept}</span>
            </li>
            <li>
              <span class="contact-label">{i.contact.tku}</span>
              <span class="contact-value">{i.contact.tku_dept}</span>
            </li>
          </ul>
        </div>

        <!-- Location Card -->
        <div class="contact-card">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </div>
          <h2 class="card-title">{i.contact.location_section}</h2>
          <p class="location-text">{i.contact.location}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-12);
    font-size: var(--text-lg);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
  }

  .contact-card {
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--space-8);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .contact-card:hover {
    box-shadow: 0 8px 24px var(--color-card-shadow);
    transform: translateY(-2px);
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    background-color: var(--color-tag-bg);
    color: var(--color-accent);
    border-radius: var(--border-radius);
    margin-bottom: var(--space-6);
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: var(--space-6);
  }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .contact-value {
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    word-break: break-all;
  }

  a.contact-value {
    color: var(--color-accent);
    transition: color var(--transition);
  }

  a.contact-value:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  .location-text {
    font-size: var(--text-base);
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
